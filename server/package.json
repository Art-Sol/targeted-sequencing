  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
